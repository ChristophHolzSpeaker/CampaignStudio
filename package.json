{
	"name": "campaignstudio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"supabase:login": "pnpm exec supabase login",
		"supabase:link": "pnpm exec supabase link",
		"supabase:push": "pnpm exec supabase db push --linked",
		"supabase:migrations:list": "pnpm exec supabase migration list --linked",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"test": "vitest run",
		"test:worker": "pnpm --filter ./worker test",
		"worker:dev": "pnpm --filter ./worker dev",
		"worker:deploy": "pnpm --filter ./worker exec wrangler deploy --env staging",
		"worker:deploy:staging": "pnpm --filter ./worker exec wrangler deploy --env staging",
		"worker:deploy:production": "pnpm --filter ./worker exec wrangler deploy --env production",
		"worker:check": "pnpm --filter ./worker check"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/opencode": "^0.1.6",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^22",
		"better-auth": "~1.4.21",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"postgres": "^3.4.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"supabase": "^2.84.5",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@supabase/ssr": "^0.10.0",
		"@supabase/supabase-js": "^2.101.0",
		"zod": "^4.3.6"
	}
}
